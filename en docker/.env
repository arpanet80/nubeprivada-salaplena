# ============================================================
# LDAP / ACTIVE DIRECTORY
# ============================================================
# NOTA: El código actual hace bind directo con credenciales del usuario
# (username@oep.net + password del login). LDAP_BIND_DN y LDAP_BIND_PASSWORD
# se leen pero no se usan activamente. Se mantienen por compatibilidad futura.
LDAP_URL=ldap://PTSDC01.oep.net
LDAP_BIND_DN=CN=svc_ldap,OU=Servicios,DC=oep,DC=net
LDAP_BIND_PASSWORD=clave_del_servicio_ldap
LDAP_BASE_DN=DC=oep,DC=net
LDAP_USER_SEARCH_FILTER=(sAMAccountName={{username}})

# ============================================================
# USUARIOS PERMITIDOS CON SUS ROLES
# Formato JSON: [{"usuario":"nombre","rol":1}]
# Roles: 1=Admin, 2=Rrhh, 3=Usuario
