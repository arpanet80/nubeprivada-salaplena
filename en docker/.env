# ============================================================
# PUPPETEER / CHROME (solo Linux, servidor de producción)
# ============================================================
# Ruta del ejecutable de Chromium en Ubuntu/Debian
# Para obtener la ruta: which chromium-browser
# Para instalar si no existe: sudo apt install -y chromium-browser
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# ============================================================

# WHATSAPP Web.js
# ============================================================
WHATSAPP_ENABLED=true
WHATSAPP_GROUP_NAME=Sala Plena Notificaciones
WHATSAPP_SESSION_PATH=/app/whatsapp-session
WHATSAPP_HEADLESS=true
WHATSAPP_VOCAL_NUMBERS=59167924400,75726555
WHATSAPP_MAX_RECONNECT=10

# ============================================================
# ROTACIÓN
# ============================================================
ROTATION_ENABLED=true
ROTATION_FREE_SPACE_THRESHOLD_PERCENT=20
ROTATION_SESSIONS_TO_REMOVE=5
ROTATION_MIN_AGE_DAYS=15
ROTATION_VERIFY_BACKUP_BEFORE_DELETE=true

# ============================================================
# UPLOAD
# ============================================================
UPLOAD_MAX_FILE_SIZE_MB=100
UPLOAD_MAX_FILES=50
UPLOAD_TEMP_PATH=/app/uploads/temp
UPLOAD_CLEANUP_AFTER_MINUTES=60

# ============================================================
# ENLACES COMPARTIDOS
# ============================================================
SHARE_LINK_EXPIRY_DAYS=10
SHARE_PASSWORD_LENGTH=8

NODE_ENV=production
# NODE_ENV=development

