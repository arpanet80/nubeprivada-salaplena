# EMAIL_USER: sAMAccountName para autenticación NTLM (sin @dominio)
# EMAIL_ACCOUNTFROM_ADDRESS: dirección completa para el campo From del email
# EMAIL_PASSWORD: contraseña del usuario de correo (diferente a SERVICE_ACCOUNT)
EWS_URL=https://correo.oep.org.bo/EWS/Exchange.asmx
EMAIL_AUTH_DOMAIN=OEP
EMAIL_NTLM_WORKSTATION=BACKEND
EMAIL_USER=carla.jimenez
EMAIL_PASSWORD=Bolivia2026.
